#!/usr/bin/env ruby

require 'bundler/inline'

gemfile do
  gem 'puma'
  gem 'cafe_car', path: '~/code/@craft-concept/cafe_car'
  gem 'potter', path: '~/code/@craft-concept/potter'
  gem 'sqlite3'
  gem 'thor'
  gem "better_errors"
  gem "binding_of_caller"
end

require "rails/all"

module Voip
  class Application < Rails::Application
    config.eager_load = false
    config.consider_all_requests_local = true
  end
end

CafeCar.auto_resolve!(Voip)

Potter.database(:voip_ms)
Rails.application.initialize!
Potter.migrate!

module Voip
  class Request < Potter::Request
    root "https://voip.ms/api/v1/rest.php"

    scope :function, -> { params(method: _1.to_s) }
    scope :auth, -> { params(api_username: ENV["VOIP_MS_USERNAME"],
                             api_password: ENV["VOIP_MS_PASSWORD"]) }
  end

  class Response < Potter::Response
  end
end

module Voip
  class CLI < Thor
    desc "console", "Start the console"
    def console
      TOPLEVEL_BINDING.irb
    end

    desc :getip, "Get my IP"
    def getip
      pp Voip::Request.auth.function(:getIP).response!
    end

    desc "last", "Print last request and response"
    def last
      pp Voip::Request.last
      pp Voip::Response.last
    end

    desc "server", "Start a rails server"
    def server
      require "puma/configuration"

      Rails.application.routes.draw do
        mount CafeCar::Engine => "/"
        scope module: :voip, as: :voip do
          resources :requests
          resources :responses
        end
      end

      conf = Puma::Configuration.new do |c|
        c.app Rails.application
        c.port 3002
        c.log_requests
      end

      Puma::Launcher.new(conf).run
    end
  end
end

Voip::CLI.start(ARGV)
