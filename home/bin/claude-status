#!/usr/bin/env bash
#
# claude-status — Claude Code statusLine command + usage-cache harvester.
#
# Claude Code runs this on every render and pipes the session JSON on stdin.
# We pull out the plan-cap usage (rate_limits.five_hour / seven_day) plus this
# session's model, context tokens, and cost; write them to a per-session cache
# file (~/.cache/claude-usage/usage.<project>); and print a compact one-line
# footer for the pane.
#
# Cache contract (consumers: holdco's bin/holdco-tokens, bin/self-clear):
# one KEY=VALUE file per project dir, keyed by workspace.project_dir basename
# (stable for a session's lifetime — the live cwd drifts with in-session cd).
# Keys: LABEL SESSION_ID CWD MODEL CTX_PCT COST_USD FIVE_HOUR_PCT
# FIVE_HOUR_RESET SEVEN_DAY_PCT SEVEN_DAY_RESET CTX_TOKENS CACHE_PCT
# SEND_COST LAST_TURN_TS UPDATED_AT.
#
# Cap semantics — the hard-won lesson (2026-07-01 incident): the provider's
# used_percentage is NOT monotonic within a reset window. It can legitimately
# DROP with the same resets_at (observed: 45% -> 14% mid-window while the
# authoritative OAuth usage endpoint read 14%). The predecessor script kept a
# high-water latch ("usage only rises within a window") that rejected every
# such drop and pinned the fleet at its weekly peak, over-throttling pacing
# for days. So: the freshest payload reading is ALWAYS the truth. Never max,
# never latch. We only carry the last-known value across renders whose payload
# has no rate_limits at all (null until a session's first API call), and we
# drop any carried reading whose reset epoch has passed — a reading from
# before the current window must never surface.
#
# Deps: jq + bash only (fast; runs on every prompt render). No jq -> exit 0.

set -uo pipefail

CACHE_DIR="${CLAUDE_USAGE_DIR:-$HOME/.cache/claude-usage}"
# Prompt-cache TTL: the warm-cache window is a 300s sliding timer reset on each
# turn. Bump to 3600 if the 1h extended-TTL cache is ever adopted.
CACHE_TTL_SECONDS=300
now="$(date +%s)"

input="$(cat)"

# Resolve jq even from a GUI/cron-spawned Claude whose PATH lacks Homebrew etc.
JQ="$(command -v jq 2>/dev/null || true)"
if [ -z "$JQ" ]; then
	for d in /opt/homebrew/bin /usr/local/bin /usr/bin /bin /home/linuxbrew/.linuxbrew/bin; do
		[ -x "$d/jq" ] && { JQ="$d/jq"; break; }
	done
fi
[ -n "$JQ" ] || exit 0

# Pull every field we care about in one jq pass as KEY=VALUE lines.
data="$(printf '%s' "$input" | "$JQ" -r '
	.rate_limits as $r
	| "CWD=\(.workspace.project_dir // .cwd // "")",
	  "SESSION_ID=\(.session_id // "")",
	  "TRANSCRIPT=\(.transcript_path // "")",
	  "MODEL=\(.model.display_name // "")",
	  "CTX_PCT=\(.context_window.used_percentage // "")",
	  "COST_USD=\(.cost.total_cost_usd // "")",
	  "FIVE_HOUR_PCT=\($r.five_hour.used_percentage // "")",
	  "FIVE_HOUR_RESET=\($r.five_hour.resets_at // "")",
	  "SEVEN_DAY_PCT=\($r.seven_day.used_percentage // "")",
	  "SEVEN_DAY_RESET=\($r.seven_day.resets_at // "")"
' 2>/dev/null)" || exit 0

val() { printf '%s\n' "$data" | sed -n "s/^$1=//p"; }

cwd="$(val CWD)"; [ -n "$cwd" ] || cwd="$PWD"
label="$(basename "$cwd")"
# Sanitize to a safe filename (keeps the project name readable).
label="$(printf '%s' "$label" | tr -c 'A-Za-z0-9._-' '_')"
[ -n "$label" ] || label="unknown"
CACHE_FILE="$CACHE_DIR/usage.$label"

model="$(val MODEL)"
ctx="$(val CTX_PCT)"
cost="$(val COST_USD)"
five_pct="$(val FIVE_HOUR_PCT)"
five_reset="$(val FIVE_HOUR_RESET)"
seven_pct="$(val SEVEN_DAY_PCT)"
seven_reset="$(val SEVEN_DAY_RESET)"

# The real tokens-in-context + warm-cache ratio aren't in the stdin payload —
# they live in the transcript JSONL. The latest non-sidechain assistant turn's
# .message.usage gives input_tokens / cache_read_input_tokens /
# cache_creation_input_tokens; their sum is the tokens actually fed to the
# model (the live context size), and cache_read / sum is the warm-cache hit
# ratio. Tail the file (the last assistant turn is near the end) so we don't
# read a multi-MB transcript whole on every render.
transcript="$(val TRANSCRIPT)"
ctx_tokens="" cache_pct="" send_cost="" last_turn_ts=""
if [ -n "$transcript" ] && [ -f "$transcript" ]; then
	# Emit "<total_tokens> <cache_read> <price-weighted input units> <iso_ts>".
	# The weighted units price warm/cold/write at their real multipliers (read
	# 0.1x, write 1.25x, fresh input 1x) so the send-cost is exact.
	usage="$(tail -n 400 "$transcript" 2>/dev/null | tac | "$JQ" -rc '
		select(.type == "assistant" and (.isSidechain | not) and (.message.usage != null))
		| .timestamp as $ts
		| .message.usage
		| (.input_tokens // 0) as $in
		| (.cache_read_input_tokens // 0) as $rd
		| (.cache_creation_input_tokens // 0) as $cw
		| ($in + $rd + $cw) as $tot
		| select($tot > 0)
		| "\($tot) \($rd) \($in + $rd * 0.1 + $cw * 1.25) \($ts // "")"' 2>/dev/null | head -1)"
	if [ -n "$usage" ]; then
		read -r ctx_tokens read_tok weighted_in ts_iso <<<"$usage"
		# ISO-8601 (e.g. 2026-06-27T06:44:39.949Z) -> epoch for idle/TTL math.
		[ -n "${ts_iso:-}" ] && last_turn_ts="$(date -d "$ts_iso" +%s 2>/dev/null || true)"
		cache_pct="$(awk -v r="$read_tok" -v t="$ctx_tokens" \
			'BEGIN { if (t > 0) printf "%.0f", r * 100 / t }')"
		# Input $/token by model family. Public API rates; on a subscription
		# plan this is an equivalent-cost ESTIMATE, not a bill.
		price="0.000005" # Opus / unknown fallback ($5 /1M)
		case "$(printf '%s' "$model" | tr '[:upper:]' '[:lower:]')" in
		*sonnet*) price="0.000003" ;; # $3 /1M
		*haiku*)  price="0.000001" ;; # $1 /1M
		esac
		send_cost="$(awk -v w="$weighted_in" -v p="$price" 'BEGIN { printf "%.2f", w * p }')"
	fi
fi

# Carry-forward: when THIS render's payload lacks a field, keep the last-known
# value from the cache — rate_limits is null until the session's first API
# call, and the transcript block can miss on a fresh session. Cap readings are
# only carried while their reset epoch is still in the future: once a window
# has rolled, a pre-roll reading is meaningless and is dropped, not shown.
# NOTE deliberately absent: no high-water latch. A payload that carries
# rate_limits always wins, even when the % went DOWN in the same window —
# see the header. The freshest provider reading is the truth.
prior() { sed -n "s/^$1=//p" "$CACHE_FILE" 2>/dev/null; }
if [ -f "$CACHE_FILE" ]; then
	if [ -z "$five_pct" ]; then
		five_pct="$(prior FIVE_HOUR_PCT)"; five_reset="$(prior FIVE_HOUR_RESET)"
		if [[ "$five_reset" =~ ^[0-9]+$ ]] && ((five_reset <= now)); then
			five_pct="" five_reset=""
		fi
	fi
	if [ -z "$seven_pct" ]; then
		seven_pct="$(prior SEVEN_DAY_PCT)"; seven_reset="$(prior SEVEN_DAY_RESET)"
		if [[ "$seven_reset" =~ ^[0-9]+$ ]] && ((seven_reset <= now)); then
			seven_pct="" seven_reset=""
		fi
	fi
	[ -n "$ctx_tokens" ]   || ctx_tokens="$(prior CTX_TOKENS)"
	[ -n "$cache_pct" ]    || cache_pct="$(prior CACHE_PCT)"
	[ -n "$send_cost" ]    || send_cost="$(prior SEND_COST)"
	[ -n "$last_turn_ts" ] || last_turn_ts="$(prior LAST_TURN_TS)"
fi

# Write the cache atomically (latest render for this label wins).
mkdir -p "$CACHE_DIR" 2>/dev/null
{
	printf 'LABEL=%s\n' "$label"
	printf 'SESSION_ID=%s\n' "$(val SESSION_ID)"
	printf 'CWD=%s\n' "$cwd"
	printf 'MODEL=%s\n' "$model"
	printf 'CTX_PCT=%s\n' "$ctx"
	printf 'COST_USD=%s\n' "$cost"
	printf 'FIVE_HOUR_PCT=%s\n' "$five_pct"
	printf 'FIVE_HOUR_RESET=%s\n' "$five_reset"
	printf 'SEVEN_DAY_PCT=%s\n' "$seven_pct"
	printf 'SEVEN_DAY_RESET=%s\n' "$seven_reset"
	printf 'CTX_TOKENS=%s\n' "$ctx_tokens"
	printf 'CACHE_PCT=%s\n' "$cache_pct"
	printf 'SEND_COST=%s\n' "$send_cost"
	printf 'LAST_TURN_TS=%s\n' "$last_turn_ts"
	printf 'UPDATED_AT=%s\n' "$now"
} >"$CACHE_FILE.tmp.$$" 2>/dev/null && mv "$CACHE_FILE.tmp.$$" "$CACHE_FILE" 2>/dev/null

# Liveness-prune sibling caches, at most once an hour: delete usage.* files
# with no live claude/node process at their CWD AND no update in >24h — dead
# sessions from finished work (their stale readings otherwise linger for
# consumers to trip over). Linux-only (/proc); a no-op elsewhere.
prune_corpses() {
	local marker="$CACHE_DIR/.last-prune" last=0
	[ -f "$marker" ] && last="$(cat "$marker" 2>/dev/null || echo 0)"
	[[ "$last" =~ ^[0-9]+$ ]] || last=0
	((now - last < 3600)) && return
	printf '%s' "$now" >"$marker" 2>/dev/null
	[ -d /proc/1 ] || return
	declare -A live
	local p link pid comm f fcwd fupd
	for p in /proc/[0-9]*/cwd; do
		link="$(readlink "$p" 2>/dev/null)" || continue
		[ -n "$link" ] || continue
		pid="${p#/proc/}"; pid="${pid%/cwd}"
		comm="$(cat "/proc/$pid/comm" 2>/dev/null)" || continue
		case "$comm" in claude | node) live["$link"]=1 ;; esac
	done
	for f in "$CACHE_DIR"/usage.*; do
		[ -f "$f" ] || continue
		[ "$f" = "$CACHE_FILE" ] && continue
		fcwd="$(sed -n 's/^CWD=//p' "$f" | head -1)"
		fupd="$(sed -n 's/^UPDATED_AT=//p' "$f" | head -1)"
		[[ "$fupd" =~ ^[0-9]+$ ]] || fupd=0
		[ -n "${live[$fcwd]:-}" ] && continue
		((now - fupd > 86400)) && rm -f "$f"
	done
}
prune_corpses 2>/dev/null

# ---- render the pane footer -------------------------------------------------
#
# Three logical clusters, divided by a dimmed " │ ":
#   <model>  │  <Nk ctx> · <NN% cached> · ~$<send-cost>  │  5h NN% · 7d NN%
# Color carries health, not decoration: cache% is GREEN warm / YELLOW <50 /
# RED <20 (low cache = expensive cold reads); caps are GREEN low / YELLOW ≥70
# / RED ≥90. ANSI is suppressed under NO_COLOR.
if [ -n "${NO_COLOR:-}" ]; then
	DIM="" GRN="" YLW="" RED="" RST=""
else
	DIM=$'\e[2m' GRN=$'\e[32m' YLW=$'\e[33m' RED=$'\e[31m' RST=$'\e[0m'
fi

iround() { printf '%.0f' "$1" 2>/dev/null || printf '%s' "$1"; }
# Compact token count: 638718 -> "639k", 950 -> "950".
fmt_k() {
	local n="$1"
	if [ "$n" -ge 1000 ] 2>/dev/null; then printf '%dk' $(((n + 500) / 1000)); else printf '%s' "$n"; fi
}
# Color a cap % by the high-is-bad thresholds.
cap_color() {
	local p; p="$(iround "$1")"
	if [ "$p" -ge 90 ] 2>/dev/null; then printf '%s' "$RED"
	elif [ "$p" -ge 70 ] 2>/dev/null; then printf '%s' "$YLW"
	else printf '%s' "$GRN"; fi
}
# A cap reading is displayable only while its window is still open.
cap_current() { [ -n "$1" ] && { ! [[ "$2" =~ ^[0-9]+$ ]] || (($2 > now)); }; }

# Group 1: model (dimmed — static, least urgent).
g1=""
[ -n "$model" ] && g1="${DIM}${model}${RST}"

# Group 2: context size + cache hit %.
g2_parts=()
if [ -n "$ctx_tokens" ]; then
	# Large context is a soft "/clear" nudge — yellow past ~120k.
	ctx_color=""
	[ "$ctx_tokens" -ge 120000 ] 2>/dev/null && ctx_color="$YLW"
	g2_parts+=("${ctx_color}$(fmt_k "$ctx_tokens") ctx${RST}")
fi
if [ -n "$cache_pct" ]; then
	cc="$GRN"
	[ "$cache_pct" -lt 50 ] 2>/dev/null && cc="$YLW"
	[ "$cache_pct" -lt 20 ] 2>/dev/null && cc="$RED"
	g2_parts+=("${cc}${cache_pct}% cached${RST}")
fi
# Cache-freshness window: whether the warm prompt cache is STILL ALIVE for the
# NEXT message. Shown as the ABSOLUTE clock time the 300s TTL expires (e.g.
# →2:34p), not a countdown, BECAUSE the statusLine re-renders only on
# conversation activity — a countdown would freeze mid-tick and lie; an
# absolute time stays correct on a stale paint. Green warm / red cold.
if [ -n "$last_turn_ts" ]; then
	idle=$((now - last_turn_ts))
	if [ "$idle" -lt "$CACHE_TTL_SECONDS" ] 2>/dev/null; then
		expiry="$(date -d "@$((last_turn_ts + CACHE_TTL_SECONDS))" '+%-I:%M%P' 2>/dev/null)"
		g2_parts+=("${GRN}→${expiry%m}${RST}") # strip the trailing m: 2:34pm -> 2:34p
	else
		g2_parts+=("${RED}cold${RST}")
	fi
fi
# Per-turn input/context send-cost — informational, kept dim.
[ -n "$send_cost" ] && g2_parts+=("${DIM}~\$${send_cost}${RST}")
# Cumulative session $ — dim, distinct from the per-turn send-cost (no ~).
[ -n "$cost" ] && g2_parts+=("${DIM}\$$(printf '%.2f' "$cost" 2>/dev/null)${RST}")
g2=""
((${#g2_parts[@]})) && { g2="${g2_parts[0]}"; for ((i = 1; i < ${#g2_parts[@]}; i++)); do g2+=" ${DIM}·${RST} ${g2_parts[$i]}"; done; }

# Group 3: rate caps (5h / 7d), only while their reset window is open.
g3_parts=()
cap_current "$five_pct" "$five_reset" \
	&& g3_parts+=("${DIM}5h${RST} $(cap_color "$five_pct")$(iround "$five_pct")%${RST}")
# 7d shows used%/elapsed% so burn reads against pace at a glance: 82% used vs
# only 69% through the window = running hot. Elapsed comes from the reset
# epoch over the 604800s window; if the reset isn't numeric, just used%.
if cap_current "$seven_pct" "$seven_reset"; then
	seven_seg="$(cap_color "$seven_pct")$(iround "$seven_pct")%${RST}"
	if [[ "$seven_reset" =~ ^[0-9]+$ ]]; then
		seven_elapsed="$(awk -v reset="$seven_reset" -v now="$now" 'BEGIN {
			e = (1 - (reset - now) / 604800) * 100
			if (e < 0) e = 0; if (e > 100) e = 100
			printf "%.0f", e }')"
		seven_seg="${seven_seg}${DIM}/${seven_elapsed}%${RST}"
	fi
	g3_parts+=("${DIM}7d${RST} ${seven_seg}")
fi
g3=""
((${#g3_parts[@]})) && { g3="${g3_parts[0]}"; for ((i = 1; i < ${#g3_parts[@]}; i++)); do g3+=" ${DIM}·${RST} ${g3_parts[$i]}"; done; }

# Join the non-empty groups with a dimmed box divider.
sep=" ${DIM}│${RST} "
out=""
for g in "$g1" "$g2" "$g3"; do
	[ -n "$g" ] || continue
	if [ -z "$out" ]; then out="$g"; else out+="${sep}${g}"; fi
done
[ -n "$out" ] && printf '%s' "$out"
exit 0
