#!/usr/bin/env ruby

require 'bundler/inline'

gemfile do
  gem 'puma'
  gem 'cafe_car', path: '~/code/@craft-concept/cafe_car'
  gem 'potter', path: '~/code/@craft-concept/potter'
  gem 'sqlite3'
  gem 'thor'
  gem "better_errors"
  gem "binding_of_caller"
end

require "rails/all"

module NET
  class Application < Rails::Application
    config.eager_load = false
    config.consider_all_requests_local = true
  end
end

CafeCar.auto_resolve!(NET)

Potter.database(:net_bible)
Rails.application.initialize!
Potter.migrate!

module NET
  class Request < Potter::Request
    root "https://labs.bible.org/api/"

    default_scope -> { plain }

    scope :formatting, -> { params(formatting: _1) }
    scope :passage,    -> { params(passage: _1) }
    scope :type,       -> { params(type: _1) }
    scope :votd,       -> { passage(:votd) }
    scope :random,     -> { passage(:random) }

    scope :full,  -> { formatting(:full) }
    scope :para,  -> { formatting(:para) }
    scope :plain, -> { formatting(:plain) }
  end

  class Response < Potter::Response
  end
end

module NET
  class CLI < Thor
    desc "console", "Start the console"
    def console
      TOPLEVEL_BINDING.irb
    end

    desc "votd", "Get the Verse of the Day."
    def votd
      pp NET::Request.plain.votd.response!.body
    end

    desc "last", "Print last request and response"
    def last
      pp NET::Request.last
      pp NET::Response.last
    end

    desc "server", "Start a rails server"
    def server
      require "puma/configuration"

      Rails.application.routes.draw do
        mount CafeCar::Engine => "/"
        scope module: :net, as: :net do
          resources :requests
          resources :responses
        end
      end

      conf = Puma::Configuration.new do |c|
        c.app Rails.application
        c.port 3001
        c.log_requests
      end

      Puma::Launcher.new(conf).run
    end
  end
end

NET::CLI.start(ARGV)
