{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "railway": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.railway.com"
    }
  },
  "provider": {
    "ollama-local": {
      "models": {
        "gemma4:latest": {
          "name": "Gemma 4",
          "tool_call": true
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://ollama.ibis-micro.ts.net/v1"
      }
    }
  }
}